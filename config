# Font configs
font-size = 13
bold-is-bright = true
font-feature = -calt, -liga, -dlig

# Cursor configs
cursor-color = cell-foreground
cursor-text = cell-background

# Appearance configs
theme = Catppuccin Mocha
window-theme = ghostty
gtk-titlebar = false
gtk-toolbar-style = flat

# Terminal window configs
window-height = 36
window-width = 160
window-padding-x = 4
window-padding-y = 4

# Misc
clipboard-paste-protection = false
